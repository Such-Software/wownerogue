# Such Software operated test product: monerogue.app.
# NO REAL VALUE: Monero stagenet test coins only. Never send mainnet XMR.
# Single-player test gambling mechanics pay 2x/3x test coins; crypto-match payouts stay off.
# Copy to .env, replace every CHANGE_ME value, then run `npm run preflight`.

NODE_ENV=production
RENDERER_CDN_ENABLED=false
HOST=0.0.0.0
PORT=3001
TRUST_PROXY=true
TRUST_PROXY_HOPS=1
BLOCK_SOURCE=daemon

CRYPTO_TYPE=XMR
MONERO_NETWORK=stagenet
SMIRK_ENABLED=false
HOSTED_BY=https://monerogue.app
OPERATED_PRODUCT_PROFILE=such-monerogue-stagenet
EXPLORER_TX_URL=

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=monerogue
DB_USER=monerogue
DB_PASSWORD=CHANGE_ME_STRONG_DATABASE_PASSWORD
ADMIN_API_KEY=CHANGE_ME_WITH_OPENSSL_RAND_HEX_32

# Exact public operator/disclosure metadata for the Such Software operated service.
OPERATOR_NAME=Such Software
OPERATOR_CONTACT_URL=mailto:apps@such.software
OPERATOR_CONTACT_LABEL=apps@such.software
LEGAL_POLICY_VERSION=2026-07-22-v1
TERMS_EFFECTIVE_DATE=2026-07-22
MINIMUM_AGE=18
PAID_ACKNOWLEDGEMENT_REQUIRED=true
# Optional plain-language notice supplied after jurisdiction-specific legal review.
# RESTRICTED_LOCATIONS_NOTICE=

# The original solo game remains available for free and through both test-coin entry paths.
PAYMENTS_ENABLED=true
FREE_PLAY_ENABLED=true
PAYMENT_MODES=direct,credits
ALLOW_MIXED_MODE=true
PREFER_CREDITS_FIRST=true

# NO REAL VALUE: 0.01 stagenet XMR per direct run; escape pays 2x, treasure escape pays 3x.
DIRECT_PAYMENT_ENABLED=true
DIRECT_GAME_PRICE=10000000000
DIRECT_REQUIRES_ADDRESS=true
DIRECT_ALLOW_GUEST_PLAY=false
DIRECT_PAYOUTS_ENABLED=true
DIRECT_PAYOUT_ESCAPE=2.0
DIRECT_PAYOUT_TREASURE=3.0

CREDITS_ENABLED=true
CREDITS_PER_GAME=1
CREDITS_REQUIRES_ADDRESS=true
CREDITS_PAYOUTS_ENABLED=true
CREDITS_PAYOUT_BASE=10000000000
CREDITS_PAYOUT_ESCAPE=2.0
CREDITS_PAYOUT_TREASURE=3.0
CREDITS_PACKAGES='[{"id":"small","credits":10,"price":"90000000000","bonus":0},{"id":"medium","credits":20,"price":"170000000000","bonus":2}]'

# Stagenet-test-coin-only payout switch and caps. Mainnet acknowledgement deliberately stays off.
PAYOUTS_ENABLED=true
ALLOW_MAINNET_PAYOUTS=false
PAYOUT_MIN_AMOUNT=1000000000
PAYOUT_MAX_PER_GAME=50000000000
PAYOUT_BATCH_INTERVAL=300
PAYMENT_CONFIRMATIONS=1
PAYOUT_MAX_RETRIES=3
MAX_PAYOUT_BATCH_SIZE=50
BALANCE_WARN=100000000000
BALANCE_CRITICAL=50000000000
LATE_PAYMENT_RECONCILE_HOURS=72
LATE_PAYMENT_RECONCILE_BATCH=100

# Deliberately blank: NO REAL VALUE stagenet events are suppressed locally and must not reach a
# real accounting sink. Startup rejects a configured financial-event sink on this network.
FINANCIAL_EVENT_SINK_URL=
FINANCIAL_EVENT_SINK_TOKEN=
FINANCIAL_EVENT_ACCOUNT_REF=wowngeon:xmr-stagenet-test

PRIMARY_WALLET_ENDPOINT=http://127.0.0.1:38083
WALLET_RPC_USER=monerogue
WALLET_RPC_PASSWORD=CHANGE_ME_STRONG_RPC_PASSWORD
PRIMARY_RPC_ENDPOINT=http://127.0.0.1:38081
FALLBACK_RPC_ENDPOINT=http://127.0.0.1:38081
RPC_POLL_INTERVAL=2000

DIFFICULTY_PRESET=casino
EARLY_ENTRY_ENABLED=true
EARLY_ENTRY_FREE_MODE=true
EARLY_ENTRY_CREDITS_MODE=true

TAVERN_ENABLED=true
TAVERN_TICK_MS=100
MATCH_ENABLED=true
MATCH_RULESET_ID=race
MATCH_MAX_PLAYERS=4
MATCH_PAID_ENTROPY_DELAY_BLOCKS=2
MATCH_PAID_ENTROPY_CONFIRMATIONS=2
MATCH_TICK_MS=250
MATCH_MIN_DURATION_MS=20000
MATCH_HARD_CEILING_MS=240000
MATCH_CREDITS_COST=1
# Operated PvP may use free/prestige economies, but never a crypto-pot/race payout economy.
MATCH_CRYPTO_RACE_ENABLED=false
MATCH_PAYOUTS_ENABLED=false
