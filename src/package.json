{
  "name": "wownerogue",
  "version": "1.0.0",
  "description": "Block-timed browser roguelike with solo, Tavern, and configurable PvP modes for Wownero and Monero.",
  "main": "index.js",
  "scripts": {
    "start": "NODE_ENV=production node index.js",
    "preflight": "NODE_ENV=production node scripts/preflight.js",
    "dev": "NODE_ENV=development node index.js",
    "debug": "NODE_ENV=debug node index.js",
    "test": "jest --runInBand",
    "capture:pvp": "node scripts/pvp-capture.js",
    "canary:stagenet": "node scripts/stagenet-financial-canary.js",
    "db:migrate:clone": "node scripts/migrate-disposable-clone.js",
    "db:create": "node scripts/setup_db.js",
    "db:drop": "node scripts/setup_db.js drop",
    "db:reset": "npm run db:drop && npm run db:create"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "config": {
    "debug": {
      "enabled": true,
      "console_logging": true,
      "debug_hotkeys": true,
      "simulated_blocks": false
    },
    "production": {
      "enabled": true,
      "console_logging": false,
      "debug_hotkeys": false,
      "simulated_blocks": false
    }
  },
  "author": "Such Software <apps@such.software>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Such-Software/wownerogue.git"
  },
  "bugs": {
    "url": "https://github.com/Such-Software/wownerogue/issues"
  },
  "homepage": "https://github.com/Such-Software/wownerogue#readme",
  "dependencies": {
    "axios": "^1.16.0",
    "dotenv": "^16.0.3",
    "express": "^4.21.3",
    "nostr-tools": "^2.23.9",
    "pg": "^8.15.5",
    "qrcode": "^1.5.3",
    "resend": "^4.0.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tweetnacl": "^1.0.3",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "playwright-core": "^1.61.1"
  }
}
